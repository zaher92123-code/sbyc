# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (Email)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@alseebbay.om
RESEND_FROM_NAME=Al Seeb Bay Parking

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Al Seeb Bay Marina

# Cron Job Security (generate a strong random string)
CRON_SECRET=your-secure-random-cron-secret-here

# Timezone
NEXT_PUBLIC_TIMEZONE=Asia/Muscat

# Vercel Cron (set in vercel.json or dashboard)
# CRON_JOB_SCHEDULE=0 6 * * *  (runs daily at 6am Muscat time)
